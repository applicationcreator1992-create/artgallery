COMPANY_NAME="LilyaArt"

SITE_NAME="LilyaArt"

# Shopify Configuration
SHOPIFY_STOREFRONT_ACCESS_TOKEN="your-storefront-access-token"
SHOPIFY_REVALIDATION_SECRET="your-revalidation-secret"
SHOPIFY_ADMIN_ACCESS_TOKEN="your-admin-access-token"
SHOPIFY_CLIENT_ID="your-app-client-id"
SHOPIFY_CLIENT_SECRET="your-app-client-secret"
SHOPIFY_STORE_DOMAIN="https://your-store.myshopify.com"

# Site Configuration
SITE_NAME=LilyaArt
COMPANY_NAME=LilyaArt

# Collections Configuration
HOMEPAGE_MAX_COLLECTIONS=8
COLLECTION_CACHE_TIME=days

# Dynamic Collection Handles (comma-separated)
COLLECTION_EXCLUDE_HANDLES=,hidden-homepage-carousel,hidden-homepage-featured-items

COLLECTION_PRIORITY_HANDLES=paintings,photography

COLLECTION_FEATURED_HANDLES=digital-art,sculptures



# Collection Display Settings

COLLECTION_SHOW_TITLE=true

COLLECTION_PRIORITY_IMAGES=4

COLLECTION_GRID_COLS_SM=2

COLLECTION_GRID_COLS_LG=3

COLLECTION_GRID_COLS_XL=4



# Analytics (optional)

NEXT_PUBLIC_GA_ID=

NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

